const express = require('express');
const { body } = require('express-validator');
const LeaderboardEntry = require('../models/LeaderboardEntry');
const { requireAuth } = require('../middleware/auth');
const { validate } = require('../middleware/validators');

const router = express.Router();

// GET /api/leaderboard?mazeShareId=abc&limit=20
router.get('/', async (req, res) => {
  const { mazeShareId, limit = 20 } = req.query;
  const filter = mazeShareId ? { mazeShareId } : {};
  const entries = await LeaderboardEntry.find(filter)
    .sort({ score: 1 })
    .limit(Math.min(Number(limit), 100))
    .populate('user', 'username');
  res.json(entries);
});

// POST /api/leaderboard — submit a run
router.post(
  '/',
  requireAuth,
  [
    body('algorithm').isIn(['astar', 'dijkstra', 'bfs', 'dfs', 'greedy']),
    body('pathLength').isInt({ min: 0 }),
    body('nodesExplored').isInt({ min: 0 }),
    body('timeTakenMs').isFloat({ min: 0 }),
    body('mazeShareId').optional().isString(),
  ],
  validate,
  async (req, res) => {
    try {
      const { algorithm, pathLength, nodesExplored, timeTakenMs, mazeShareId } = req.body;
      const score = LeaderboardEntry.computeScore(pathLength, nodesExplored, timeTakenMs);

      const entry = await LeaderboardEntry.create({
        user: req.user._id,
        username: req.user.username,
        algorithm,
        pathLength,
        nodesExplored,
        timeTakenMs,
        score,
        mazeShareId,
      });

      res.status(201).json({ score, entryId: entry._id });
    } catch (err) {
      res.status(500).json({ error: err.message });
    }
  }
);

module.exports = router;
