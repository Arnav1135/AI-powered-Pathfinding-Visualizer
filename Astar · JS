const MinHeap = require('./MinHeap');
const {
  encode,
  decode,
  getNeighbors,
  getCost,
  reconstructPath,
  manhattan,
  euclidean,
  chebyshev,
  validateGridInput,
} = require('./grid');

const HEURISTICS = {
  manhattan,
  euclidean,
  chebyshev,
};

/**
 * A* Search Algorithm.
 *
 * Finds the shortest path from `start` to `end` on `grid` using the
 * A* algorithm with a configurable heuristic. Optimal and complete when
 * the heuristic is admissible (never overestimates true cost).
 *
 * @param {number[][]} grid - 2D grid; 0 = open, 1 = wall, 2-9 = weighted cell
 * @param {{row:number, col:number}} start
 * @param {{row:number, col:number}} end
 * @param {object} [options]
 * @param {boolean} [options.allowDiagonal=false] - allow 8-directional movement
 * @param {'manhattan'|'euclidean'|'chebyshev'} [options.heuristic='manhattan']
 * @param {boolean} [options.recordSteps=true] - record visited order for visualization
 *
 * @returns {{
 *   path: {row:number, col:number}[],
 *   visitedOrder: {row:number, col:number}[],
 *   cost: number,
 *   found: boolean,
 *   nodesExplored: number,
 * }}
 */
function aStar(grid, start, end, options = {}) {
  validateGridInput(grid, start, end);

  const {
    allowDiagonal = false,
    heuristic = 'manhattan',
    recordSteps = true,
  } = options;

  const heuristicFn = HEURISTICS[heuristic] || manhattan;
  const cols = grid[0].length;

  const startKey = encode(start.row, start.col, cols);
  const endKey = encode(end.row, end.col, cols);

  const gScore = new Map([[startKey, 0]]);
  const cameFrom = new Map();
  const visitedOrder = [];
  const closedSet = new Set();

  const openHeap = new MinHeap((a, b) => a.f - b.f);
  openHeap.push({ key: startKey, f: heuristicFn(start, end) });

  let nodesExplored = 0;

  while (!openHeap.isEmpty()) {
    const { key: currentKey } = openHeap.pop();

    if (closedSet.has(currentKey)) continue;
    closedSet.add(currentKey);
    nodesExplored++;

    const current = decode(currentKey, cols);
    if (recordSteps) visitedOrder.push(current);

    if (currentKey === endKey) {
      return {
        path: reconstructPath(cameFrom, endKey, cols),
        visitedOrder,
        cost: gScore.get(endKey),
        found: true,
        nodesExplored,
      };
    }

    const neighbors = getNeighbors(grid, current.row, current.col, allowDiagonal);

    for (const neighbor of neighbors) {
      const neighborKey = encode(neighbor.row, neighbor.col, cols);
      if (closedSet.has(neighborKey)) continue;

      const moveCost = getCost(
        grid,
        neighbor.row,
        neighbor.col,
        allowDiagonal,
        current.row,
        current.col
      );
      const tentativeG = gScore.get(currentKey) + moveCost;

      if (tentativeG < (gScore.get(neighborKey) ?? Infinity)) {
        cameFrom.set(neighborKey, currentKey);
        gScore.set(neighborKey, tentativeG);
        const f = tentativeG + heuristicFn(neighbor, end);
        openHeap.push({ key: neighborKey, f });
      }
    }
  }

  return {
    path: [],
    visitedOrder,
    cost: Infinity,
    found: false,
    nodesExplored,
  };
}

module.exports = aStar;
