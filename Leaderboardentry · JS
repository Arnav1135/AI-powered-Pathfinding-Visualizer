const mongoose = require('mongoose');

const leaderboardSchema = new mongoose.Schema(
  {
    user: {
      type: mongoose.Schema.Types.ObjectId,
      ref: 'User',
      required: true,
    },
    username: { type: String, required: true }, // denormalised for fast reads
    maze: {
      type: mongoose.Schema.Types.ObjectId,
      ref: 'SavedMaze',
    },
    mazeShareId: { type: String },
    algorithm: {
      type: String,
      enum: ['astar', 'dijkstra', 'bfs', 'dfs', 'greedy'],
      required: true,
    },
    pathLength: { type: Number, required: true },
    nodesExplored: { type: Number, required: true },
    timeTakenMs: { type: Number, required: true },
    // Composite score: lower is better
    score: { type: Number, required: true },
  },
  { timestamps: true }
);

leaderboardSchema.index({ mazeShareId: 1, score: 1 });
leaderboardSchema.index({ score: 1 });

// score = pathLength * 10 + nodesExplored + timeTakenMs * 0.01
leaderboardSchema.statics.computeScore = function (pathLength, nodesExplored, timeTakenMs) {
  return Math.round(pathLength * 10 + nodesExplored + timeTakenMs * 0.01);
};

module.exports = mongoose.model('LeaderboardEntry', leaderboardSchema);
